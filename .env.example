# Supabase (database only — auth is handled by SSO)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SECRET_KEY=your-secret-key

# LightningWorks SSO
NEXT_PUBLIC_SSO_URL=https://sso.lightningworks.io
NEXT_PUBLIC_SSO_APP_SLUG=anamayos

# Retreat Guru API (for import)
RG_API_URL=https://anamaya.secure.retreat.guru/api/v1
RG_API_TOKEN=your-retreat-guru-api-token
